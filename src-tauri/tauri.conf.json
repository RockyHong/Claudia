{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-plugin-schema/refs/heads/main/schema.json",
  "productName": "Claudia",
  "version": "0.3.1",
  "identifier": "com.claudia.desktop",
  "build": {
    "frontendDist": "../packages/web/dist",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claudia",
        "width": 640,
        "height": 800,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:48901"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
