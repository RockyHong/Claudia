{
  "name": "cldi",
  "version": "0.1.0",
  "description": "A personal receptionist for all your Claude Code agents",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/web"
  ],
  "bin": {
    "cldi": "./bin/cli.js",
    "claudia-standalone": "./bin/standalone.js"
  },
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "build": "npm run build --workspace=packages/web",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "bundle:server": "node scripts/bundle-server.js",
    "build:sea": "node scripts/build-sea.js",
    "build:sea:x64": "node scripts/build-sea.js --arch x64",
    "dev:tauri": "npm run build:sea:x64 && cargo build --release --manifest-path src-tauri/Cargo.toml",
    "build:tauri": "npm run build:sea && npx tauri build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockyHong/Claudia.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "receptionist",
    "session-monitor"
  ],
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^4.1.0"
  }
}
