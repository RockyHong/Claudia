{
  "name": "@rockyhong/claudia",
  "version": "0.2.0",
  "description": "A personal receptionist for all your Claude Code agents",
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/web"
  ],
  "bin": {
    "cldi": "./bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "packages/server/src/**/*.js",
    "!packages/server/src/**/*.test.js",
    "packages/server/package.json",
    "packages/web/dist/"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "npm run dev --workspace=packages/server",
    "build": "npm run build --workspace=packages/web",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "bundle:server": "node scripts/bundle-server.js",
    "build:sea": "npm run clean && node scripts/build-sea.js",
    "build:sea:x64": "npm run clean && node scripts/build-sea.js --arch x64",
    "dev:tauri": "npm run build:sea:x64 && cargo build --release --manifest-path src-tauri/Cargo.toml",
    "build:tauri": "npm run build:sea && npx tauri build",
    "clean": "node scripts/clean.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RockyHong/Claudia.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "receptionist",
    "session-monitor"
  ],
  "dependencies": {
    "adm-zip": "^0.5.16",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tauri-apps/cli": "^2.10.1",
    "esbuild": "^0.27.4",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^4.1.0"
  }
}
