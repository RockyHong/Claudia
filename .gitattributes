# Normalize line endings
* text=auto
# Explicitly declare text files
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.svelte text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
# Windows batch files need CRLF
*.bat text eol=crlf
# Binary assets — do not diff, do not normalize
*.webm binary
*.mp4 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico filter=lfs diff=lfs merge=lfs -text
*.woff binary
*.woff2 binary
